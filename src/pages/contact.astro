---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteProfile } from "@/lib/site-content";
---

<BaseLayout
  title="Contact — Hein Htet Aung"
  description="Get in touch with Hein Htet Aung."
>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-20">
    <h1 class="section-heading mb-4">Get In Touch</h1>
    <p class="text-neutral-400 mb-10 max-w-lg">
      Have a project in mind or just want to connect? Reach out directly through one of the channels below.
    </p>

    <div class="card-glow space-y-4">
      <a href={`mailto:${siteProfile.email}`} class="btn-primary">Email me</a>
      <a href={siteProfile.linkedinUrl} target="_blank" rel="noopener noreferrer" class="btn-ghost">LinkedIn</a>
      <a href={siteProfile.githubUrl} target="_blank" rel="noopener noreferrer" class="btn-ghost">GitHub</a>
    </div>
  </div>
</BaseLayout>
